{
  "name": "personal-ops-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first personal operations server with subscription-authenticated AI CLI adapters.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env --import tsx src/server.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start:dist": "node --env-file-if-exists=.env dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
